{
  "name": "subtitle-studio-deploy",
  "private": true,
  "type": "module",
  "scripts": {
    "cf:deploy": "wrangler deploy",
    "cf:types": "wrangler types",
    "cf:containers": "wrangler containers list",
    "vercel:preview": "npx vercel",
    "vercel:deploy": "npx vercel --prod",
    "vercel:pull": "npx vercel pull --yes"
  },
  "dependencies": {
    "@cloudflare/containers": "^0.2.0"
  },
  "devDependencies": {
    "wrangler": "^4.102.0"
  },
  "cloudflare": {
    "bindings": {
      "DEEPSEEK_API_KEY": {
        "description": "DeepSeek API key used by the Python container for translation and vocabulary analysis."
      },
      "APP_PASSWORD": {
        "description": "Shared access password required before friends can use the web app."
      }
    }
  }
}
